{
  "name": "videor",
  "version": "0.1.0",
  "private": true,
  "description": "Éditeur de diaporamas vidéo simple pour Linux",
  "author": {
    "name": "Patrick Nouhailler",
    "email": "patrick.nouhailler@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/nouhailler/videor2",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "VITE_DEV_SERVER_URL=http://127.0.0.1:5173 concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "start": "electron .",
    "test": "vitest run",
    "package:linux": "npm run build && electron-builder --linux AppImage deb"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "fr.videor.app",
    "productName": "Vidéor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "deb"],
      "category": "AudioVideo",
      "artifactName": "Videor-${version}-${arch}.${ext}"
    }
  }
}
